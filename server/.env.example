# --- Telegram bot ---
# Token from @BotFather
TELEGRAM_BOT_TOKEN=
# Public URL where the React mini-app is served (must be HTTPS for Telegram WebApp)
WEBAPP_URL=https://example.com/xpgame

# --- OpenAI ---
# Used for goal analysis, plan generation, and motivational messages.
OPENAI_API_KEY=
# Optional override — defaults to gpt-5
OPENAI_PLAN_MODEL=gpt-5

# --- PostgreSQL ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=xpgame_db
DB_USER=xpgame_user
DB_PASSWORD=

# --- Server ---
PORT=3007
NODE_ENV=production
